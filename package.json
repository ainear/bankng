{
  "name": "bankng",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e:prepare": "pnpm --filter @bankng/web build && pnpm --filter @bankng/admin build && pnpm --filter @bankng/banker build",
    "test:e2e": "pnpm test:e2e:prepare && PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright dotenv -e .env.local -- playwright test",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright install chromium",
    "db:generate": "pnpm --filter @bankng/db db:generate",
    "db:migrate": "pnpm --filter @bankng/db db:migrate",
    "db:seed": "pnpm --filter @bankng/db db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.9",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "typescript-eslint": "^8.50.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
