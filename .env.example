# Bankng local environment
# Copy to .env.local and fill in real values

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-local-secret"
ADMIN_EMAIL="admin@bankng.local"
ADMIN_PASSWORD="replace-with-a-strong-local-password"
BANKER_EMAIL="banker@bankng.local"

# Supabase project
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ACCESS_TOKEN=""

# Supabase Postgres
# Project Settings -> Database -> Connection string
DATABASE_URL="postgresql://postgres:DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?schema=public&sslmode=require"
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?schema=public&sslmode=require"

# Provider access tokens (local automation only)
GITHUB_TOKEN=""
VERCEL_TOKEN=""

# Optional future integrations
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
POSTHOG_KEY=""
POSTHOG_HOST=""
