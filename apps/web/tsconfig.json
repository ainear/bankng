{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@bankng/db": [
        "../../packages/db/src/index.ts"
      ],
      "@bankng/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@bankng/analytics": [
        "../../packages/analytics/src/index.ts"
      ],
      "@bankng/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
