# Bankng Production Environment
# Copy to .env.production.local for each app and fill in real values

# ==========================================
# SHARED (all apps)
# ==========================================
NODE_ENV=production

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Supabase project
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Supabase Postgres
DATABASE_URL="postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres?schema=public&sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres?schema=public&sslmode=require"

# ==========================================
# WEB (https://bankng.com)
# ==========================================
NEXT_PUBLIC_APP_URL="https://bankng.com"
AUTH_URL="https://bankng.com"

# ==========================================
# ADMIN (https://admin.bankng.com)
# ==========================================
# NEXT_PUBLIC_APP_URL and AUTH_URL overridden per project in Vercel dashboard
ADMIN_EMAIL="admin@bankng.com"
ADMIN_PASSWORD=""

# ==========================================
# BANKER (https://banker.bankng.com)
# ==========================================
BANKER_EMAIL="banker@bankng.com"

# ==========================================
# API (https://api.bankng.com)
# ==========================================
# API route: GET /api/compare, /api/rates, /api/banks

# ==========================================
# CRAWLER (Railway)
# ==========================================
# DATABASE_URL — same Postgres instance
# Crawl config is baked into the binary at build time
# To trigger crawl: curl -X POST https://crawler.bankng.com/crawl
